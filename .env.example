# For getting financial data to power the hedge fund
# Get your Financial Datasets API key from https://financialdatasets.ai/
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# For running LLMs hosted by openai (GPT 5, etc.)
# Get your OpenAI API key from https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key

# Moonshot (Kimi) — OpenAI 兼容接口，使用 OPENAI_API_KEY 存放 Kimi key
# 取消注释并填入你的 Moonshot key 即可启用 Kimi 模型
# 获取 key：https://platform.moonshot.cn/
# OPENAI_API_BASE=https://api.moonshot.cn/v1
# 使用方式（CLI）：
#   poetry run python src/main.py --ticker NVDA --model moonshot-v1-8k --model-provider OpenAI
# 支持的 model 名称：moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k

# For running LLMs hosted by anthropic (claude-4-sonnet, claude-4.1-opus, etc.)
# Get your Anthropic API key from https://anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# For running LLMs hosted by deepseek (deepseek-chat, deepseek-reasoner, etc.)
# Get your DeepSeek API key from https://deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# For running LLMs hosted by groq (deepseek, llama3, etc.)
# Get your Groq API key from https://groq.com/
GROQ_API_KEY=your-groq-api-key

# For running LLMs hosted by gemini (gemini-2.5-flash, gemini-2.5-pro)
# Get your Google API key from https://ai.dev/
GOOGLE_API_KEY=your-google-api-key

# For running LLMs hosted by xAI (Grok 4, etc.)
XAI_API_KEY=your-xai-api-key

# For running LLM GigaChat
GIGACHAT_API_KEY=your-gigachat-api-key

# For running LLMs hosted by OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key

# For running LLMs hosted by Microsoft Azure OpenAI (gpt-4o, gpt-4o-mini, etc.)
# Get your Azure OpenAI API settings from https://oai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment-name

# ── Crypto Trading (CCXT) ────────────────────────────────────────────────────
# Supported exchanges: binance, okx, bybit, kraken, coinbase, etc.
# Get API keys from your exchange account settings.
CCXT_EXCHANGE=binance
CCXT_API_KEY=your-ccxt-api-key
CCXT_API_SECRET=your-ccxt-api-secret
# Set to "true" to use the exchange sandbox / testnet (strongly recommended initially)
CCXT_SANDBOX=true

# ── US Stock Live Trading (Alpaca) ───────────────────────────────────────────
# Sign up at https://alpaca.markets/ – paper trading is free with no real money.
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
# Paper trading URL (change to https://api.alpaca.markets for live)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Social Media Data ────────────────────────────────────────────────────────
# Reddit: create an app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=ai-hedge-fund/1.0 by YourUsername

# StockTwits (optional – public endpoints work without a token, but token
# increases rate limits): https://api.stocktwits.com/developers/apps
STOCKTWITS_ACCESS_TOKEN=your-stocktwits-access-token

# Telegram: create a bot via @BotFather and add it to the crypto channels/groups
# you want to monitor. Comma-separated chat IDs (negative numbers for groups).
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210

# ── Sentiment Analysis ───────────────────────────────────────────────────────
# FinBERT model from HuggingFace (auto-downloaded on first run)
FINBERT_MODEL=ProsusAI/finbert

# ── On-Chain Data ─────────────────────────────────────────────────────────────
# Optional: Glassnode API key for on-chain metrics (MVRV, NVT, etc.)
# Without a key the onchain_agent falls back to CoinGecko (free, limited metrics)
# Get your key from https://studio.glassnode.com/
GLASSNODE_API_KEY=